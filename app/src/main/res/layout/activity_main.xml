<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/activity_main_contador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_helo_world"
        android:textSize="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.6"
        android:textColor="@color/black"/>

    <Button
        android:id="@+id/activity_main_btn_aumentar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/activity_main_contador"
        app:layout_constraintStart_toStartOf="@id/main"
        app:layout_constraintEnd_toEndOf="@id/main"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:text="@string/app_botton_aumentar"
        android:backgroundTint="@color/purple"
        />

    <Button
        android:id="@+id/activity_main_btn_diminuir"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/activity_main_btn_aumentar"
        app:layout_constraintStart_toStartOf="@id/main"
        app:layout_constraintEnd_toEndOf="@id/main"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:text="@string/app_botton_diminuir"
        android:backgroundTint="@color/purple"
        />

    <Button
        android:id="@+id/activity_main_btn_resetar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/activity_main_btn_diminuir"
        app:layout_constraintStart_toStartOf="@id/main"
        app:layout_constraintEnd_toEndOf="@id/main"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:text="@string/app_botton_resetar"
        android:backgroundTint="@color/purple"
        />


</androidx.constraintlayout.widget.ConstraintLayout>